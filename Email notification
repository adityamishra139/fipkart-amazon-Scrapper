# Add this new function to send emails
def send_price_alert(product, amazon_price, kreo_price, difference_percentage):
    subject = f"Price Alert: {product}"
    body = f"""
    Price deviation detected for {product}:
    
    Amazon Price: ₹{amazon_price}
    Kreo Tech Price: ₹{kreo_price}
    Price Difference: {difference_percentage:.2f}%
    
    Please review and take necessary action.
    """
    
    msg = MIMEMultipart()
    msg['From'] = EMAIL_SENDER
    msg['To'] = ', '.join(EMAIL_RECIPIENTS)
    msg['Subject'] = subject
    msg.attach(MIMEText(body, 'plain'))
    
    try:
        server = smtplib.SMTP(SMTP_SERVER, SMTP_PORT)
        server.starttls()
        server.login(EMAIL_SENDER, EMAIL_PASSWORD)
        server.send_message(msg)
        server.quit()
        print(f"Price alert sent for {product}")
    except Exception as e:
        print(f"Failed to send email alert: {e}")

